# ═══════════════════════════════════════════════════════════════
#  AttendAI — Environment Configuration
#  Скопируйте этот файл в .env и заполните значения
# ═══════════════════════════════════════════════════════════════

# ─── SECURITY ───────────────────────────────────────────────────
# Генерация: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-characters

# Время жизни токенов (в минутах)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── DATABASE (PostgreSQL) ──────────────────────────────────────
POSTGRES_DB=attendai
POSTGRES_USER=attendai
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── REDIS ──────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_HOST=redis
REDIS_PORT=6379

# ─── MINIO (S3 Storage) ─────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET_PHOTOS=attendai-photos
MINIO_BUCKET_REPORTS=attendai-reports
MINIO_BUCKET_VIDEOS=attendai-videos

# ─── FIRST ADMIN USER ────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@yourschool.edu
FIRST_ADMIN_PASSWORD=Admin123!
FIRST_ADMIN_NAME=Системный Администратор

# ─── ML / FACE RECOGNITION ──────────────────────────────────────
# Порог уверенности для распознавания (0.0 - 1.0)
FACE_RECOGNITION_THRESHOLD=0.6
# Размер батча для обработки видео
CAMERA_BATCH_SIZE=4
# Интервал обработки кадров (секунды)
CAMERA_PROCESS_INTERVAL=0.5
# Путь к ML-моделям
ML_MODELS_DIR=/app/ml_models
# Модель InsightFace (buffalo_l, buffalo_m, buffalo_s)
INSIGHTFACE_MODEL=buffalo_l
# Использовать GPU (0 = CPU, >0 = GPU device id)
FACE_GPU_ID=-1

# ─── NOTIFICATIONS ───────────────────────────────────────────────
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourschool.edu
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=AttendAI System

# Telegram Bot (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── APPLICATION ─────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Часовой пояс
TIMEZONE=Asia/Almaty

# CORS origins (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── MONITORING ──────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ─── ШКОЛА / УНИВЕРСИТЕТ ─────────────────────────────────────────
INSTITUTION_NAME=Образовательное учреждение
INSTITUTION_SHORT_NAME=ОУ
INSTITUTION_LOGO_URL=
